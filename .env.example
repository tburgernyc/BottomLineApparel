# ═══════════════════════════════════════════════
# Bottom Line Apparel — Environment Variables
# Copy this file to .env.local for local dev
# Set these in Vercel Dashboard → Settings → Environment Variables
# ═══════════════════════════════════════════════

# ── Printful API (required for product catalog) ──
# Get your API key from: https://www.printful.com/dashboard/store/api-key
PRINTFUL_API_KEY=your_printful_api_key_here

# Your Printful store ID (found in the Printful dashboard URL)
PRINTFUL_STORE_ID=your_printful_store_id_here

# ── Klaviyo (optional — for email list capture) ──
# Private API key from: https://www.klaviyo.com/account#api-keys-tab
# If not set, /api/subscribe will log signups to console only
KLAVIYO_PRIVATE_KEY=your_klaviyo_private_key_here

# Your Klaviyo List ID (the list subscribers are added to)
# Find in: Klaviyo → Audience → Lists → click list → URL contains the ID
KLAVIYO_LIST_ID=your_klaviyo_list_id_here

# ── Mailchimp (alternative to Klaviyo — optional) ──
# Uncomment and fill in if you prefer Mailchimp over Klaviyo
# Also uncomment the Mailchimp block in api/subscribe.js
# MAILCHIMP_API_KEY=your_mailchimp_api_key_here
# MAILCHIMP_LIST_ID=your_mailchimp_audience_id_here
# MAILCHIMP_SERVER=us1
